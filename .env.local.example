# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API). Never commit .env.local.

# Project URL and anon (public) key — safe to expose to the browser,
# access is enforced by Postgres RLS policies (see supabase/migrations/).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypasses RLS entirely. Server-only, used exclusively by
# scripts/migrate-to-supabase.ts. Never prefix with NEXT_PUBLIC_, never
# import lib/supabase/service.ts from anything under app/**.
SUPABASE_SERVICE_ROLE_KEY=

# Optional, local development only. Points app/api/audio/[file]/route.ts at
# the on-disk Micmac audio archive so recordings play before
# scripts/upload-audio-blob.mjs has run. Defaults to ../Micmac/audio (a
# sibling directory next to this repo) if unset — that default only makes
# sense on a dev machine with the archive checked out there, and does NOT
# exist in production. In production this route is unused once the audio
# manifest carries real Vercel Blob URLs; leave this unset.
# MICMAC_AUDIO_DIR=

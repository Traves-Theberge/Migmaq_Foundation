# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# nested projects (e.g. dictionary-ui/) — the rules above are root-anchored
# and don't reach subfolders, so mirror the important ones unanchored here.
node_modules/
.next/
dist/
.turbo/

# Playwright
/test-results/
/playwright-report/
/blob-report/

# transient backup written by scripts/build-dictionary.mjs before each rebuild
public/assets/dictionary.backup.json
.env*.local
